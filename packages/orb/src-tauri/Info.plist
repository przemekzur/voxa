<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Merged into the macOS bundle Info.plist by Tauri. Required so macOS will
     grant microphone access; without it the OS denies/ crashes the mic request.
     Ignored on Windows/Linux. -->
<plist version="1.0">
<dict>
  <key>NSMicrophoneUsageDescription</key>
  <string>Voxa uses the microphone to hear and respond to you.</string>
</dict>
</plist>
